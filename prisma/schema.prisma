// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model About {
  id                  Int      @id @default(autoincrement())
  name                String   @db.VarChar(100)
  title               String   @db.VarChar(200)
  titleTh             String?  @db.VarChar(200)
  bio                 String   @db.Text
  bioTh               String?  @db.Text
  avatarUrl           String?  @db.VarChar(500)
  resumeUrl           String?  @db.VarChar(500)
  githubUrl           String?  @db.VarChar(300)
  linkedinUrl         String?  @db.VarChar(300)
  email               String   @db.VarChar(200)
  phone               String?  @db.VarChar(50)
  location            String?  @db.VarChar(200)
  locationTh          String?  @db.VarChar(200)
  status              String?  @db.VarChar(500)
  statusTh            String?  @db.VarChar(500)
  availability        String?  @db.VarChar(100)
  availabilityTh      String?  @db.VarChar(100)
  yearsOfExperience   Int?     @default(0)
  strengths           String?  @db.Text
  strengthsTh         String?  @db.Text
  goals               String?  @db.Text
  goalsTh             String?  @db.Text
  nowLearning         String?  @db.Text
  nowLearningTh       String?  @db.Text
  updatedAt           DateTime @updatedAt
}

model Skill {
  id          Int     @id @default(autoincrement())
  category    String  @db.VarChar(100)
  categoryTh  String? @db.VarChar(100)
  name        String  @db.VarChar(100)
  nameTh      String? @db.VarChar(100)
  iconUrl     String? @db.VarChar(300)
  proficiency Int     @default(0)
  sortOrder   Int     @default(0)
  isVisible   Boolean @default(true)

  @@unique([name, category])
  @@index([isVisible, sortOrder])
  @@index([category])
}

model Project {
  id                    Int            @id @default(autoincrement())
  title                 String         @db.VarChar(200)
  titleTh               String?        @db.VarChar(200)
  description           String         @db.Text
  descriptionTh         String?        @db.Text
  longDescription       String?        @db.Text
  longDescriptionTh     String?        @db.Text
  techStack             String[]
  stack                 String?        @db.VarChar(100)
  githubUrl             String?        @db.VarChar(300)
  liveUrls              String[]
  isFeatured            Boolean        @default(false)
  isVisible             Boolean        @default(true)
  sortOrder             Int            @default(0)
  createdAt             DateTime       @default(now())
  images                ProjectImage[]
  caseStudyProblem      String?        @db.Text
  caseStudyProblemTh    String?        @db.Text
  caseStudySolution     String?        @db.Text
  caseStudySolutionTh   String?        @db.Text
  caseStudyChallenges   String?        @db.Text
  caseStudyChallengesTh String?        @db.Text
  caseStudyResults      String?        @db.Text
  caseStudyResultsTh    String?        @db.Text
  architectureDiagram   String?        @db.Text
  architectureDiagramTh String?        @db.Text
  techStackUsed         String?        @db.Text
  techStackUsedTh       String?        @db.Text
  timeline              String?        @db.VarChar(200)
  timelineTh            String?        @db.VarChar(200)
  teamSize              String?        @db.VarChar(100)
  teamSizeTh            String?        @db.VarChar(100)
  keyLearnings          String?        @db.Text
  keyLearningsTh        String?        @db.Text

  @@index([isVisible, isFeatured, sortOrder])
}

model ProjectImage {
  id        Int     @id @default(autoincrement())
  projectId Int
  url       String  @db.VarChar(500)
  sortOrder Int     @default(0)
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, sortOrder])
}

model Experience {
  id            Int       @id @default(autoincrement())
  company       String    @db.VarChar(200)
  position      String    @db.VarChar(200)
  positionTh    String?   @db.VarChar(200)
  description   String?   @db.Text
  descriptionTh String?   @db.Text
  startDate     DateTime
  endDate       DateTime?
  isCurrent     Boolean   @default(false)
  sortOrder     Int       @default(0)

  @@index([sortOrder])
}

model Education {
  id             Int       @id @default(autoincrement())
  degree         String    @db.VarChar(200)
  degreeTh       String?   @db.VarChar(200)
  institution    String    @db.VarChar(200)
  fieldOfStudy   String?   @db.VarChar(200)
  fieldOfStudyTh String?   @db.VarChar(200)
  startDate      DateTime
  endDate        DateTime?
  gpa            Decimal?  @db.Decimal(3, 2)
  description    String?   @db.Text
  descriptionTh  String?   @db.Text
  sortOrder      Int       @default(0)

  @@index([sortOrder])
}

model BlogPost {
  id          Int         @id @default(autoincrement())
  title       String      @db.VarChar(300)
  titleTh     String?     @db.VarChar(300)
  slug        String      @unique @db.VarChar(300)
  excerpt     String?     @db.Text
  excerptTh   String?     @db.Text
  content     String      @db.Text
  contentTh   String?     @db.Text
  tags        String[]
  isPublished Boolean     @default(false)
  isFeatured  Boolean     @default(false)
  readingTime Int?
  publishedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  images      BlogImage[]

  @@index([isPublished, publishedAt])
  @@index([slug])
}

model BlogImage {
  id        Int      @id @default(autoincrement())
  postId    Int
  url       String   @db.VarChar(500)
  sortOrder Int      @default(0)
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, sortOrder])
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  email     String   @db.VarChar(200)
  subject   String?  @db.VarChar(300)
  message   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([isRead])
  @@index([createdAt])
  @@index([createdAt, isRead])
}

model AdminUser {
  id             Int       @id @default(autoincrement())
  username       String    @unique @db.VarChar(100)
  passwordHash   String    @db.VarChar(300)
  failedAttempts Int       @default(0)
  lockedUntil    DateTime?
  createdAt      DateTime  @default(now())
}

model EngineeringHighlight {
  id        Int     @id @default(autoincrement())
  title     String  @db.VarChar(200)
  titleTh   String? @db.VarChar(200)
  icon      String? @db.VarChar(100)
  sortOrder Int     @default(0)
  isVisible Boolean @default(true)

  @@index([isVisible, sortOrder])
}
